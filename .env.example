# ============================================
# MERIDIAN — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys.
# Keys are optional — sources without keys degrade gracefully.
#
# IMPORTANT: Do NOT put comments on the same line as values.

# Browser Use (REQUIRED for HUMINT agents and ARIA chat)
# Get at: https://browser-use.com
BROWSER_USE_API_KEY=

# LLM — for AI trade ideas and analyst chat
# Supports: anthropic, openai, gemini, mistral, ollama
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=

# Free API keys (unlock more data sources)
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# NASA FIRMS: https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=
# EIA: https://www.eia.gov/opendata/
EIA_API_KEY=
# Maritime AIS: https://aisstream.io
AISSTREAM_API_KEY=
# ACLED: https://acleddata.com/user/register
ACLED_EMAIL=
ACLED_PASSWORD=
# Cloudflare Radar: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Server
PORT=3117
REFRESH_INTERVAL_MINUTES=15

# Telegram alerts (optional)
# 1. Create bot via @BotFather on Telegram
# 2. Get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Convex (auto-set by npx convex dev)
# NEXT_PUBLIC_CONVEX_URL= (set in meridian-app/.env.local)
